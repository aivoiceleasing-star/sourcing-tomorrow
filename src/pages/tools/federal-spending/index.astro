---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FederalSpending from '../../../components/tools/FederalSpending';
---

<BaseLayout title="Federal Spending Tracker" description="Track U.S. federal procurement spending by agency, category, and amount using data from USASpending.gov.">
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-10">
        <a href="/tools/" class="inline-flex items-center gap-1.5 text-brand-700 hover:text-brand-800 text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          All Tools
        </a>
        <h1 class="text-3xl lg:text-5xl font-extrabold text-neutral-900 mb-4">Federal Spending Tracker</h1>
        <p class="text-xl text-neutral-500">Explore U.S. federal procurement spending by agency, industry, and fiscal year. Powered by USASpending.gov open data.</p>
      </div>
      <FederalSpending client:load />
    </div>
  </section>
</BaseLayout>
